        padding: 1rem;
        width: 514px;
        height: 60px;
        user-select: none;
        background-color: rgba(255, 255, 255, 0.23);
        backdrop-filter: blur(25px);
        z-index: 2;
        border-bottom: 0.7px solid rgba(151, 151, 151, 0.168);
}
}

