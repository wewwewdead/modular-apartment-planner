import React from 'react';

import { EmptyState } from '../../../components/EmptyState';

interface VaultEmptyStateProps {
  categoryName?: string;
}

export function VaultEmptyState({ categoryName }: VaultEmptyStateProps) {
  return (
    <EmptyState
      title={categoryName ? `No items in ${categoryName}` : 'No items yet'}
      message="Tap the + button to add your first item to this category."
    />
  );
}
