export const STAR_COLORS = ['#5f92ff', '#ff5fa2', '#5fffb0', '#ffd75f', '#b05fff', '#ff8a5f'];

export const HOME_SCALE = 0.8;
export const GUEST_SCALE = 0.05;

export const simpleHash = (str) => {
    let h = 0;
    for (let i = 0; i < str.length; i++) {
        h = ((h << 5) - h + str.charCodeAt(i)) | 0;
    }
    return Math.abs(h);
};

export const userHomeCoords = (userId) => {
    if (!userId) return { x: 0, y: 0 };
    const mid = Math.floor(userId.length / 2);
    const xHash = simpleHash(userId.slice(0, mid));
    const yHash = simpleHash(userId.slice(mid));
    const x = (xHash % 50001) / 50000 * 50000 - 25000;
    const y = (yHash % 50001) / 50000 * 50000 - 25000;
    return { x, y };
};

export const getStarColor = (userId) => {
    if (!userId) return STAR_COLORS[0];
    return STAR_COLORS[simpleHash(userId) % STAR_COLORS.length];
};

export const getStarRadius = (likeCount) => {
    const likes = Math.min(likeCount || 0, 20);
    return 6 + likes * 0.3;
};

export const extractSnippet = (post) => {
    if (post.post_type === 'canvas' && post.canvas_doc?.snippets) {
        return post.canvas_doc.snippets
            .map(s => s?.text || '')
            .filter(Boolean)
            .join(' ')
            .slice(0, 200);
    }
    if (typeof post.content === 'string') {
        try {
            const parsed = JSON.parse(post.content);
            const extractText = (node) => {
                if (!node) return '';
                if (typeof node.text === 'string') return node.text;
                if (Array.isArray(node.children)) {
                    return node.children.map(extractText).join('');
                }
                return '';
            };
            return extractText(parsed.root || parsed).slice(0, 200);
        } catch {
            return post.content.slice(0, 200);
        }
    }
    return '';
};

export const hexToRgba = (hex, alpha) => {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `rgba(${r},${g},${b},${alpha})`;
};
