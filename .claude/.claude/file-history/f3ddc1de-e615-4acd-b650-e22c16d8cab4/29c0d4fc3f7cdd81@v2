.canvasContainer {
  width: 100%;
  height: 100%;
  overflow: hidden;
  position: relative;
  background: var(--color-background);
}

.svg {
  width: 100%;
  height: 100%;
  display: block;
}

.statusBar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 26px;
  background: var(--color-panel-bg);
  border-top: 1px solid var(--color-border);
  box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.03);
  display: flex;
  align-items: center;
  gap: var(--space-xl);
  padding: 0 var(--space-lg);
  font-size: 11px;
  letter-spacing: 0.02em;
  color: var(--color-text-secondary);
  font-family: var(--font-blueprint);
  user-select: none;
}

.statusMessage {
  margin-left: auto;
  color: var(--color-accent);
  font-family: var(--font-ui);
  font-weight: 500;
  animation: fadeInUp 0.2s var(--ease-out);
}
