.canvasContainer {
  width: 100%;
  height: 100%;
  overflow: hidden;
  position: relative;
  background: var(--color-background);
}

.svg {
  width: 100%;
  height: 100%;
  display: block;
}

.statusBar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 24px;
  background: var(--color-panel-bg);
  border-top: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  padding: 0 var(--space-md);
  font-size: 11px;
  color: var(--color-text-secondary);
  font-family: var(--font-blueprint);
}

.statusMessage {
  margin-left: auto;
  color: var(--color-accent);
}
