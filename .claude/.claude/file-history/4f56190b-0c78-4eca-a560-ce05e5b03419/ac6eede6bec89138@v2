# Server port
PORT=3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE=your-service-role-key-here

# Cloudflare Turnstile (CAPTCHA)
SECRET_KEY=your-turnstile-secret-key
SITE_KEY=your-turnstile-site-key

# Facebook (optional, for OG share metadata)
META_FB_APP_ID=your-fb-app-id

# Metrics endpoint auth (optional)
METRICS_TOKEN=your-metrics-token

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://iskrib.com,http://localhost:5173

# Cluster mode (optional, for multi-core production)
CLUSTER_ENABLED=false
WORKER_COUNT=2
