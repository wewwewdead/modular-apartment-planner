.layout-picker-container{
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0.5rem 0.9rem;
    border-radius: 25px;
    background-color: transparent;
    border: 1.5px solid currentColor;
    cursor: pointer;
    user-select: none;
    font-family: "Lexend Deca", sans-serif;
