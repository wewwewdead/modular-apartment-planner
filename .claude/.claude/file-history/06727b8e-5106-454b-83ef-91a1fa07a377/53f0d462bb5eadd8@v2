    justify-content: flex-end;
    align-items: center;
    width: 95%;
    padding: 1rem;
    height: 60px;
}
.add-collection-button {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0.5rem 0.8rem;
    border-radius: 10px;
    background-color: var(--accent-dark);
    color: var(--bg-primary);
    user-select: none;
    cursor: pointer;
    font-weight: 600;
    transition: background-color 0.15s ease, transform 0.1s ease;
