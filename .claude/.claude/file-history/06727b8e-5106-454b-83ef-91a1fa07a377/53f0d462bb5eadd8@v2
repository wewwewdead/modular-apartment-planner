}
.not-collected-cards:hover {
    background-color: var(--bg-selection);
}
.collected-cards {
    position: relative;
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    width: 98%;
    height: fit-content;
    background-color: var(--bg-selection);
    padding: 0.5rem;
    border-radius: 10px;
    cursor: pointer;
    border: 2px solid var(--accent-purple);
    transition: background-color 0.15s ease, border-color 0.15s ease;
}
.not-collected-title {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
}
.if-collected-text {
    display: flex;
    width: fit-content;
    height: fit-content;
    padding: 0.1rem 0.4rem;
    font-size: 0.6rem !important;
    font-weight: 600 !important;
    color: var(--bg-primary);
    background-color: var(--accent-sage);
    border-radius: 5px;
}
.not-collected-text {
    font-size: 0.9rem;
    color: var(--text-secondary);
}
.not-collected-list-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    overflow-y: auto;
    overflow-x: hidden;
}

/* ── Collection name & description (journal cards page) ── */
.collection-Name-description {
    display: flex;
    justify-content: space-between;
    width: 95%;
    padding: 1rem;
    height: fit-content;
    border-top: 0.7px solid var(--border-light);
    border-bottom: 0.7px solid var(--border-light);
}
.container1 {
    display: flex;
    flex-direction: column;
    width: 50%;
    height: 100%;
    gap: 0.5rem;
}
.collection-name {
    display: flex;
    width: fit-content;
    height: fit-content;
    font-family: "Lexend Deca", sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    line-height: 1.4;
    color: var(--text-primary);
    letter-spacing: -0.02em;
}
.collection-description-container {
    display: flex;
    width: fit-content;
    height: fit-content;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-secondary);
}
.container2 {
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
    width: 50%;
    height: fit-content;
}
.save-button-container {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 0.5rem;
    padding-top: 0.5rem;
    color: var(--text-primary);
}
.save-collected-post-bttn {
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 10px;
    cursor: pointer;
    background-color: var(--accent-dark);
    transition: background-color 0.15s ease, transform 0.1s ease;
    color: var(--bg-primary);
    font-weight: 600;
    font-family: inherit;
}
.save-collected-post-bttn:hover {
    background-color: var(--accent-dark-hover);
}
.save-collected-post-bttn:active {
    transform: scale(0.97);
}
.save-collected-post-bttn:focus-visible {
    outline: 2px solid var(--accent-purple);
    outline-offset: 2px;
}

/* ── Saving/loading overlays ── */
.saving-loding-container {
    display: flex;
    position: absolute;
    width: 95%;
    height: 95%;
    justify-content: center;
    align-items: center;
    background-color: var(--bg-glass);
    backdrop-filter: blur(5px);
    border-radius: 15px;
    gap: 1rem;
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--text-primary);
    z-index: 131;
}
.deleting-collection-loading-container {
    position: absolute;
    display: flex;
    z-index: 132;
    width: 100%;
    height: 100%;
    justify-content: center;
    align-items: center;
    background-color: var(--bg-glass);
    backdrop-filter: blur(5px);
    border-radius: 15px;
}

/* ── Toast: deleted message ── */
.deleted-message-container {
    position: fixed;
    z-index: 200;
    background-color: var(--color-danger);
    padding: 0.6rem 1.2rem;
    border-radius: 10px;
    color: #ffffff;
    font-weight: 600;
    bottom: 2rem;
    left: 0;
    right: 0;
    margin: 0 auto;
    width: fit-content;
    transform: translateY(0);
    max-width: calc(100% - 2rem);
    text-align: center;
    box-shadow: var(--shadow-dropdown);
    animation: toast-enter 0.2s ease;
    white-space: nowrap;
}

/* ── Toast: privacy updated ── */
.update-privacy-message-container {
    position: fixed;
    z-index: 200;
    background-color: var(--color-success);
    padding: 0.6rem 1.2rem;
    border-radius: 10px;
    color: #ffffff;
    font-weight: 600;
    bottom: 2rem;
    left: 0;
    right: 0;
    margin: 0 auto;
    width: fit-content;
    transform: translateY(0);
    max-width: calc(100% - 2rem);
    text-align: center;
    box-shadow: var(--shadow-dropdown);
    animation: toast-enter 0.2s ease;
    white-space: nowrap;
}

/* ── Profile/viewer collection cards ── */
.collection-container {
    display: flex;
    justify-content: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    width: 90%;
    padding: 1.25rem;
    height: fit-content;
    margin-top: 1rem;
    background-color: var(--bg-glass);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border-radius: 20px;
    border: 0.7px solid var(--border-light);
    margin-bottom: 4rem;
    transition: box-shadow 0.35s ease, border-color 0.35s ease;
}
.collection-container:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    border-color: var(--bg-glass-border);
}
.collection-container-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding-bottom: 0.5rem;
    border-bottom: 0.5px solid var(--border-light);
    margin-bottom: 0.25rem;
}
.collection-container-title {
    margin: 0;
    font-family: "Lexend Deca", sans-serif;
    font-size: 0.92rem;
    font-weight: 700;
    color: inherit;
    letter-spacing: -0.01em;
}
.collection-container-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 0.35rem;
    border-radius: 10px;
    background-color: var(--bg-glass);
    border: 0.5px solid var(--bg-glass-border);
    font-family: "Lexend Deca", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--text-muted);
}
.collection-profile-loading-container {
    display: flex;
    width: 100%;
    min-height: 180px;
    justify-content: center;
    align-items: center;
}
.collection-private-blocker {
    display: flex;
    justify-content: center;
    align-items: center;
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(12px) saturate(0.8);
    -webkit-backdrop-filter: blur(12px) saturate(0.8);
    z-index: 136;
    border-radius: 14px;
    cursor: default;
    user-select: none;
}
.private-blocker-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
}
.private-blocker-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.85);
}
.private-blocker-label {
    font-family: "Lexend Deca", sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.04em;
    text-transform: uppercase;
}
.viewer {
    display: flex;
    width: 100%;
    height: 20px;
}

/* ── View User Collection page (enhanced) ── */
.view-collection-header {
    position: fixed;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1rem;
    width: inherit;
    height: 60px;
    background-color: var(--bg-glass);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border-bottom: 0.7px solid var(--border-light);
    z-index: 135;
    user-select: none;
}
.view-collection-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 0.35rem;
    border-radius: 10px;
    background-color: var(--bg-glass);
    border: 0.5px solid var(--bg-glass-border);
    font-family: "Lexend Deca", sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--text-muted);
}
.view-collection-body {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 1rem;
    padding-top: 80px;
    min-height: 100vh;
}
.view-collection-loading {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    min-height: 200px;
}
.view-collection-description-bar {
    font-family: var(--font-serif);
    font-size: 0.88rem;
    font-weight: 400;
    line-height: 1.55;
    color: var(--text-secondary);
    padding: 0.75rem 0;
    margin-bottom: 0.75rem;
    border-bottom: 0.7px solid var(--border-light);
}

/* ── Card grid ── */
.view-collection-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.85rem;
}

/* ── Individual card ── */
.view-collection-card {
    display: flex;
    flex-direction: column;
    background-color: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 14px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}
.view-collection-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
    border-color: var(--bg-glass-border);
}

/* ── Card image ── */
.view-card-image-wrapper {
    position: relative;
    width: 100%;
    height: 160px;
    overflow: hidden;
}
.view-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease, opacity 0.2s ease;
}
.view-collection-card:hover .view-card-image {
    transform: scale(1.03);
    opacity: 0.95;
}
.view-card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.06) 0%, transparent 40%);
    pointer-events: none;
}

/* ── Card content ── */
.view-card-content {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.7rem 0.85rem 0.85rem;
}
.view-card-author {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.1rem;
}
.view-card-avatar {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    object-fit: cover;
    border: 0.5px solid var(--border-card);
}
.view-card-author-name {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-faint);
    letter-spacing: 0.01em;
}
.view-card-title {
    font-family: "Lexend Deca", sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.35;
    letter-spacing: -0.02rem;
    color: var(--text-heading);
}
.view-card-text {
    font-family: var(--font-serif);
    font-size: 0.82rem;
    font-weight: 400;
    line-height: 1.55;
    color: var(--text-body);
}

/* ── Legacy (kept for other usages) ── */
.close-viewer-container {
    display: flex;
    justify-content: flex-end;
    align-items: center;
}
.close-button {
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    transition: background-color 0.15s ease;
    color: var(--text-primary);
}
.close-button:hover {
    background-color: var(--bg-hover);
}
.close-button:focus-visible {
    outline: 2px solid var(--accent-purple);
    outline-offset: 2px;
}

/* ── Back button ── */
.back-button {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    border-radius: 8px;
    transition: background-color 0.15s ease;
    color: var(--text-primary);
}
.back-button:hover {
    background-color: var(--bg-hover);
}
.back-button:focus-visible {
    outline: 2px solid var(--accent-purple);
    outline-offset: 2px;
}

/* ══════════════════════════════════════════════
   Responsive: 768px
   ══════════════════════════════════════════════ */
@media (max-width: 768px) {
    .collection-cards {
        width: calc(50% - 0.5rem);
    }
    .collections {
        width: calc(50% - 0.5rem);
    }
    .skeleton-card {
        width: calc(50% - 0.5rem);
    }
    .collection-Name-description {
        flex-direction: column-reverse;
        width: 92%;
    }
    .container1 {
        width: 100%;
    }
    .container2 {
        width: 100%;
        justify-content: center;
    }
    .view-collection-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    .cv-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

