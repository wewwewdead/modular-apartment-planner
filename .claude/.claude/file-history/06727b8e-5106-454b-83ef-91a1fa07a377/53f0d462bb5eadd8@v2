    height: 95%;
    padding: 1rem;
    top: 100px;
    gap: 0;
    overflow-y: auto;
    overflow-x: hidden;
}
.close-bttn-container {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    width: 100%;
    height: fit-content;
}
.close-bttn {
    display: flex;
    justify-content: center;
    width: fit-content;
    height: fit-content;
    border-radius: 50%;
