import supabase from "./supabase.js";

const MILESTONES = [7, 14, 30, 50, 100];

function todayUTC() {
    return new Date().toISOString().split('T')[0];
}

function daysBetween(a, b) {
    return Math.round((new Date(b + 'T00:00:00Z') - new Date(a + 'T00:00:00Z')) / 86400000);
}

export const getStreakService = async (userId) => {
    if (!userId) return null;

    const { data, error } = await supabase
        .from('writing_streaks')
        .select('*')
        .eq('user_id', userId)
        .maybeSingle();

    if (error) {
        console.error('error fetching streak:', error.message);
        return null;
    }

    if (!data) return { current_streak: 0, longest_streak: 0, last_publish_date: null, freeze_available: false };

    const gap = data.last_publish_date ? daysBetween(data.last_publish_date, todayUTC()) : null;
    const expired = gap !== null && gap > 2;

    return {
        current_streak: expired ? 0 : data.current_streak,
        longest_streak: data.longest_streak,
        last_publish_date: data.last_publish_date,
        freeze_available: data.freeze_available,
    };
};

export const recordPublishForStreak = async (userId) => {
    if (!userId) return { streakData: null, milestone: null };

    const today = todayUTC();

    const { data: existing, error: fetchErr } = await supabase
        .from('writing_streaks')
        .select('*')
        .eq('user_id', userId)
        .maybeSingle();

    if (fetchErr) {
        console.error('error fetching streak for record:', fetchErr.message);
        return { streakData: null, milestone: null };
    }

    // First publish ever
    if (!existing) {
        const row = { user_id: userId, current_streak: 1, longest_streak: 1, last_publish_date: today, freeze_available: false, updated_at: new Date().toISOString() };
        const { error } = await supabase.from('writing_streaks').insert(row);
        if (error) console.error('error inserting streak:', error.message);
        return { streakData: error ? null : row, milestone: null };
    }

    // Already published today
    if (existing.last_publish_date === today) return { streakData: existing, milestone: null };

    const gap = daysBetween(existing.last_publish_date, today);
    let streak = existing.current_streak;
    let freeze = existing.freeze_available;
    let freezeUsed = existing.freeze_used_date;

    if (gap === 1) {
        streak += 1;
    } else if (gap === 2 && freeze) {
        streak += 1;
        freeze = false;
        freezeUsed = today;
    } else {
        streak = 1;
    }

    const longest = Math.max(existing.longest_streak, streak);

    // Grant freeze every 7 consecutive days
    if (!freeze && streak > 0 && streak % 7 === 0) freeze = true;

    const payload = {
        current_streak: streak,
        longest_streak: longest,
        last_publish_date: today,
        freeze_available: freeze,
        freeze_used_date: freezeUsed,
        freeze_last_granted: freeze ? today : existing.freeze_last_granted,
        updated_at: new Date().toISOString(),
    };

    const { error } = await supabase.from('writing_streaks').update(payload).eq('user_id', userId);
    if (error) {
        console.error('error updating streak:', error.message);
        return { streakData: null, milestone: null };
    }

    return {
        streakData: { ...existing, ...payload },
        milestone: MILESTONES.includes(streak) ? streak : null,
    };
};
