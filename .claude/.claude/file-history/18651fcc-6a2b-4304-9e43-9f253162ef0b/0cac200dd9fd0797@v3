.weekly-recap-card {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.08), rgba(134, 179, 143, 0.08));
    border: 1px solid var(--border-color, rgba(255, 255, 255, 0.1));
    border-radius: 16px;
    padding: 16px 20px;
    margin-bottom: 16px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
}

.recap-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
}

.recap-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-secondary, #a1a1aa);
}

.recap-dismiss-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-secondary, #a1a1aa);
    padding: 4px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    transition: background 0.15s ease;
}

.recap-dismiss-btn:hover {
    background: rgba(255, 255, 255, 0.08);
}

.recap-stats {
    display: flex;
    align-items: center;
    gap: 12px;
}

.recap-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 48px;
}

.recap-stat-value {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary, #fafafa);
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
}

.recap-stat-label {
    font-size: 11px;
    color: var(--text-secondary, #a1a1aa);
}

.recap-stat-divider {
    width: 1px;
    height: 28px;
    background: var(--border-color, rgba(255, 255, 255, 0.1));
    flex-shrink: 0;
}

.recap-community {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border-color, rgba(255, 255, 255, 0.08));
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.recap-community-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    color: var(--text-secondary, #a1a1aa);
}

.recap-highlight {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-primary, #fafafa);
}

.recap-avatar {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
}
