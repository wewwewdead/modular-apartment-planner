{"parentUuid":"fbd6cf52-e9a4-4a83-a73f-96fd8483524c","isSidechain":false,"userType":"external","cwd":"C:\\Users\\johnm\\gradeBot\\teacher-grade-agent","sessionId":"ffca678e-2785-440e-b7d2-13e8c6423da1","version":"2.1.50","gitBranch":"HEAD","slug":"stateless-jumping-blossom","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013TWo5VZtT5rVzVjuSsbZZP","type":"tool_result","content":"from __future__ import annotations\n\nimport json\nfrom typing import Any\n\nfrom langgraph.graph import END, StateGraph\nfrom loguru import logger\nfrom ollama import Client\n\nfrom src.agent.prompts import PLANNER_PROMPT, teacher_system_prompt\nfrom src.agent.state import AgentState, InboundMessage\nfrom src.agent.tools import AgentToolbox\nfrom src.config import AppSettings\nfrom src.db.models import DatabaseManager\nfrom src.tools.utils import parse_cancel_token, parse_confirmation_token\n\n\nclass TeacherGradeGraph:\n    def __init__(self, settings: AppSettings, db: DatabaseManager):\n        self.settings = settings\n        self.db = db\n        self.toolbox = AgentToolbox(settings, db)\n        self.ollama_client = Client(host=settings.ollama.base_url)\n        self.graph = self._build_graph()\n\n    def _build_graph(self):\n        workflow = StateGraph(AgentState)\n\n        workflow.add_node(\"load_context\", self._load_context)\n        workflow.add_node(\"plan\", self._plan_intent)\n        workflow.add_node(\"handle_image\", self._handle_image)\n        workflow.add_node(\"handle_confirm\", self._handle_confirm)\n        workflow.add_node(\"handle_cancel\", self._handle_cancel)\n        workflow.add_node(\"handle_text\", self._handle_text)\n        workflow.add_node(\"finalize\", self._finalize)\n\n        workflow.set_entry_point(\"load_context\")\n        workflow.add_edge(\"load_context\", \"plan\")\n\n        workflow.add_conditional_edges(\n            \"plan\",\n            self._route_intent,\n            {\n                \"handle_image\": \"handle_image\",\n                \"handle_confirm\": \"handle_confirm\",\n                \"handle_cancel\": \"handle_cancel\",\n                \"handle_text\": \"handle_text\",\n            },\n        )\n\n        workflow.add_edge(\"handle_image\", \"finalize\")\n        workflow.add_edge(\"handle_confirm\", \"finalize\")\n        workflow.add_edge(\"handle_cancel\", \"finalize\")\n        workflow.add_edge(\"handle_text\", \"finalize\")\n        workflow.add_edge(\"finalize\", END)\n\n        return workflow.compile()\n\n    def handle_message(self, inbound: InboundMessage) -> list[str]:\n        initial_state: AgentState = {\n            \"whatsapp_id\": inbound.whatsapp_id,\n            \"display_name\": inbound.display_name,\n            \"inbound_message_id\": inbound.message_id,\n            \"inbound_text\": inbound.text,\n            \"inbound_image_path\": inbound.image_path,\n            \"replies\": [],\n            \"errors\": [],\n            \"finished\": False,\n        }\n        final_state = self.graph.invoke(initial_state)\n        replies = final_state.get(\"replies\") or [\"I could not process this message. Please try again.\"]\n        return replies\n\n    def _load_context(self, state: AgentState) -> dict[str, Any]:\n        teacher = self.db.get_or_create_teacher(\n            whatsapp_id=state[\"whatsapp_id\"],\n            display_name=state.get(\"display_name\"),\n        )\n        language_mode = teacher.preferred_language or self.settings.agent.default_language_mode\n        return {\n            \"teacher_id\": teacher.id,\n            \"language_mode\": language_mode,\n        }\n\n    def _plan_intent(self, state: AgentState) -> dict[str, Any]:\n        text = (state.get(\"inbound_text\") or \"\").strip()\n        image_path = state.get(\"inbound_image_path\")\n\n        if image_path:\n            return {\"intent\": \"image_processing\", \"planner_steps\": [\"ocr_extract\", \"preview_excel_update\"]}\n\n        confirm_token = parse_confirmation_token(text) if text else None\n        if confirm_token:\n            return {\n                \"intent\": \"confirm_update\",\n                \"pending_token\": confirm_token,\n                \"planner_steps\": [\"apply_excel_update\", \"generate_pdf_report\"],\n            }\n\n        cancel_token = parse_cancel_token(text) if text else None","is_error":false}]},"uuid":"6d3d47cb-e2f3-478e-9b28-594e3202ced1","timestamp":"2026-02-21T14:46:28.371Z"},"normalizedMessages":[],"type":"agent_progress","prompt":"Explore the project at C:\\Users\\johnm\\gradeBot\\teacher-grade-agent thoroughly. I need to understand:\n1. What kind of project this is (language, framework)\n2. How it's meant to be run (look for package.json, requirements.txt, Makefile, README, docker-compose, etc.)\n3. Any configuration files, environment variables, or setup steps required\n4. Entry points (main files, scripts, etc.)\n\nBe very thorough - check all config files, READMEs, and any documentation about running the project.","agentId":"a41935e9b6d71fcfa"},"toolUseID":"agent_msg_01LxXDkVGdWQ3uQGCDwaT1Gd","parentToolUseID":"toolu_01X2mkb65cpRE1yXJNZQ1PMJ","uuid":"8c668846-1b00-4558-acf1-c2e8ff9f9a21","timestamp":"2026-02-21T14:46:28.424Z"}
