def _register_events(self) -> None:\n        @self.client.event(ConnectedEv)\n        def on_connected(client: Any, event: Any) -> None:  # noqa: ANN401\n            self._connected = True\n            logger.info(\"WhatsApp connected\")\n\n        @self.client.event(PairStatusEv)\n        def on_pair_status(client: Any, event: Any) -> None:  # noqa: ANN401\n            logger.info(\"WhatsApp pair status event: {}\", event)\n\n        @self.client.event(MessageEv)\n        def on_message(client: Any, event: Any) -> None:  # noqa: ANN401\n            try:\n                inbound = self._parse_inbound_event(event)\n                if inbound is None:\n                    return\n\n                replies = self.handler.handle(inbound)\n                for message in replies:\n                    self._reply_to_event(event, message)\n            except Exception:\n                logger.exception(\"Unhandled message processing exception\")\n                self._reply_to_event(\n                    event,\n                    \"I hit an internal error. Please resend your message in a moment.\",\n                )\n\n    def _parse_inbound_event(self, event: Any) -> InboundMessage | None:\n        whatsapp_id = self._extract_whatsapp_id(event)\n        message_id = self._extract_message_id(event)\n        if not whatsapp_id or not message_id:\n            logger.warning(\"Skipping event due to missing whatsapp_id or message_id\")\n            return None\n\n        text = self._extract_text(event)\n        image_path = self._save_image_if_present(event)\n        display_name = self._extract_display_name(event)\n\n        return InboundMessage(\n            whatsapp_id=whatsapp_id,\n            display_name=display_name,\n            message_id=message_id,\n            text=text,\n            image_path=str(image_path) if image_path else None,\n        )\n\n    def _extract_whatsapp_id(self, event: Any) -> str | None:\n        info = getattr(event, \"info\", None)\n        sender = getattr(info, \"sender\", None)\n        user = getattr(sender, \"user\", None)\n        server = getattr(sender, \"server\", \"s.whatsapp.net\")\n        if user:\n            return f\"{user}@{server}\"\n\n        chat = getattr(info, \"chat\", None)\n        chat_user = getattr(chat, \"user\", None)\n        chat_server = getattr(chat, \"server\", \"s.whatsapp.net\")\n        if chat_user:\n            return f\"{chat_user}@{chat_server}\"\n        return None\n\n    @staticmethod\n    def _extract_message_id(event: Any) -> str | None:\n        info = getattr(event, \"info\", None)\n        return getattr(info, \"id\", None)\n\n    @staticmethod\n    def _extract_display_name(event: Any) -> str | None:\n        info = getattr(event, \"info\", None)\n        push_name = getattr(info, \"push_name\", None)\n        if push_name:\n            return str(push_name)\n\n        sender = getattr(info, \"sender\", None)\n        return getattr(sender, \"user\", None)\n\n    def _extract_text(self, event: Any) -> str | None:\n        message = getattr(event, \"message\", None)\n        if message is None:\n            return None\n\n        conversation = getattr(message, \"conversation\", None)\n        if conversation:\n            return str(conversation)\n\n        extended = getattr(message, \"extendedTextMessage\", None)\n        if extended and getattr(extended, \"text\", None):\n            return str(extended.text)\n\n        image_message = getattr(message, \"imageMessage\", None)\n        if image_message and getattr(image_message, \"caption\", None):\n            return str(image_message.caption)\n\n        return None\n\n    def _save_image_if_present(self, event: Any) -> Path | None:\n        message = getattr(event, \"message\", None)\n        if message is None:\n            return None\n\n        image_message = getattr(message, \"imageMessage\", None)\n        if image_message is None:\n            return None\n\n        if not hasattr(self.client, \"download_any\"):\n            logger.warning(\"Current neonize client has no download_any method\")\n            return None\n\n        raw_bytes = self.client.download_any(image_message)\n        if not raw_bytes:\n            logger.warning(\"Image download returned no bytes\")\n            return None\n\n        resolved_bytes: bytes | None = None\n        if isinstance(raw_bytes, (bytes, bytearray)):\n            resolved_bytes = bytes(raw_bytes)\n        elif hasattr(raw_bytes, \"read\"):\n            resolved_bytes = raw_bytes.read()\n        elif isinstance(raw_bytes, str):\n            maybe_path = Path(raw_bytes)\n            if maybe_path.exists():\n                resolved_bytes = maybe_path.read_bytes()\n\n        if not resolved_bytes:\n            logger.warning(\"Image payload from neonize had unsupported format\")\n            return None\n\n        message_id = self._extract_message_id(event) or f\"msg_{int(time.time())}\"\n        image_path = self.settings.whatsapp.media_dir / f\"{message_id}.jpg\"\n        image_path.write_bytes(resolved_bytes)\n        return image_path\n\n    def _reply_to_event(self, event: Any, text: str) -> None:\n        info = getattr(event, \"info\", None)\n        chat = getattr(info, \"chat\", None)\n\n        if hasattr(self.client, \"reply_message\") and chat is not None:\n            self.client.reply_message(chat, event, text)\n            return\n\n        if hasattr(self.client, \"send_message\") and chat is not None:\n            self.client.send_message(chat, text)\n            return\n\n        logger.error(\"Unable to send message: no compatible send API found\")\n\n    def run_forever(self) -> None:\n        attempts = 0\n        max_attempts = self.settings.whatsapp.reconnect_max_attempts\n\n        while not self._stopping:\n            try:\n                logger.info(\"Starting WhatsApp client loop\")\n                self.client.run()\n                if self._stopping:\n                    bre